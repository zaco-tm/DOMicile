---
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'input'>, 'class' | 'type'> {
  class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<input
  type="radio"
  class={['domi-radio', className].filter(Boolean).join(' ')}
  {...rest}
/>