{
  "name": "@domi/react",
  "version": "0.1.0",
  "description": "React wrappers for DOMicile primitives",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui",
    "domicile",
    "primitives"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zaco-tm/DOMicile.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/zaco-tm/DOMicile/issues"
  },
  "homepage": "https://github.com/zaco-tm/DOMicile#readme",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  },
  "license": "MIT"
}
