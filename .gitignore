# Runtime / agent
.domi/
.superpowers/
.omo/

# Git worktree machinery (project-local feature branches).
# Linked worktrees live here so we don't pollute the main checkout.
.worktrees/

# Scratch / throwaway artifacts (untracked working files, generated media,
# in-progress downloads). Safe to delete at any time.
tmp/

# Phase planning/internal superpowers artifacts (not for public release).
# These are append-only trails from the brainstorming/planning skill that
# helped build this project; they aren't part of DOMicile itself.
docs/superpowers/

# Build artifacts
target/
**/target/
node_modules/
dist/
build/

# Astro auto-generated types and content maps (created by `astro check` and `astro dev`)
.astro/
**/.astro/
packages/astro/.astro/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Env
.env
.env.local

# Knowledge graph (generated by `npm run graph`, gitignored so each
# agent regenerates locally instead of sharing a stale map).
graphify-out/

# Cargo.lock is now tracked (pre-publish policy flip, 2026-07-11).
